# Runtime query URL (pooler) for Vercel/serverless
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Direct URL for Prisma migrations
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
CRON_SECRET="ganti-dengan-secret-acak-yang-kuat"

# Public URL is safe for browser usage
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Service role key must stay server-side only
SUPABASE_SERVICE_ROLE_KEY="isi-dari-project-settings-api"

# Bucket must be created in Supabase Storage, default: daily-pdfs
SUPABASE_PDF_BUCKET="daily-pdfs"

# Optional letterhead image
NEXT_PUBLIC_LETTERHEAD_URL="https://<domain-anda>/assets/image/logo.png"
